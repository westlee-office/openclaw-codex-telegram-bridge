TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional: restrict usage to these chat IDs (comma-separated).
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-100987654321

# Routing: auto | claw | codex | hybrid
ROUTER_MODE=auto

# Print route/debug tag at the end of each reply.
SHOW_ROUTE_DEBUG=false

# Keep last N turns per chat for Codex context.
HISTORY_TURNS=4

# Telegram polling tuning.
TELEGRAM_POLL_TIMEOUT=25
TELEGRAM_RETRY_SLEEP=2

# OpenClaw settings.
OPENCLAW_BIN=openclaw
OPENCLAW_AGENT=main
OPENCLAW_TIMEOUT=120
OPENCLAW_LOCAL=false
# OPENCLAW_THINKING=medium
# OPENCLAW_EXTRA_ARGS=--profile work
OPENCLAW_MIN_CHARS=80
# Pattern delimiter is "|".
# OPENCLAW_LOW_QUALITY_PATTERNS=i don't know|모르겠|죄송

# Codex CLI settings.
CODEX_BIN=codex
CODEX_TIMEOUT=180
CODEX_WORKDIR=/Users/westlee/Projects
# CODEX_MODEL=gpt-5.3-codex
# CODEX_PROFILE=default
# CODEX_EXTRA_ARGS=--sandbox workspace-write
