# Use `crontab -e` and paste entries you want.
# Change <CHAT_ID> and paths if needed.

SHELL=/bin/zsh
PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Every morning 09:00 - Codex only
0 9 * * * cd /Users/westlee/Projects/openclaw-codex-telegram-bridge && /usr/bin/python3 cron_run.py --mode codex --chat-id <CHAT_ID> --prompt-file cron/prompts/morning_briefing.txt --show-route >> logs/cron-codex.log 2>&1

# Every workday 13:00 - Hybrid rewrite
0 13 * * 1-5 cd /Users/westlee/Projects/openclaw-codex-telegram-bridge && /usr/bin/python3 cron_run.py --mode hybrid --chat-id <CHAT_ID> --prompt-file cron/prompts/lunch_checkin.txt --show-route >> logs/cron-hybrid.log 2>&1

# Every evening 20:30 - Auto mode
30 20 * * * cd /Users/westlee/Projects/openclaw-codex-telegram-bridge && /usr/bin/python3 cron_run.py --mode auto --chat-id <CHAT_ID> --prompt-file cron/prompts/evening_summary.txt --show-route >> logs/cron-auto.log 2>&1

# Optional: start live Telegram bridge after reboot in codex mode.
# @reboot cd /Users/westlee/Projects/openclaw-codex-telegram-bridge && ROUTER_MODE=codex /usr/bin/python3 bridge.py >> logs/bridge-codex.log 2>&1
